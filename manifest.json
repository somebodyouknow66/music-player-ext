{
  "manifest_version": 3,
  "name": "the-one-music-player",
  "permissions": ["storage", "identity", "contextMenus", "offscreen", "declarativeNetRequestWithHostAccess"],
  "host_permissions": ["https://www.googleapis.com/*", "https://www.youtube.com/*"],
  "version": "0.1.0", 
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://www.youtube.com;"
  }
}